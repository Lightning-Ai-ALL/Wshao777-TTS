# 在 main.py 或 api/ledger_api.py 中
from core.kpi_engine import KPIEngine

@app.post("/api/ledger/record")
def record_event(
    agent_id: int,
    event_type: str,
    amount: float,
    metadata: str = None,
    db: Session = Depends(get_db)
):
    # 1. 查詢 Agent
    agent = db.query(Agent).filter(Agent.id == agent_id).first()
    if not agent:
        raise HTTPException(status_code=404, detail="Agent not found")

    # 2. 決定當前季度（例如從 metadata 中提取，或自動生成）
    from datetime import datetime
    now = datetime.utcnow()
    quarter = f"{now.year}-Q{(now.month-1)//3 + 1}"

    # 3. 取得該 Agent 在該季度的 KPI 實際值（需從外部系統或本機計算）
    #    此處示範：可從 metadata 提取，或從資料庫中最近記錄取得
    #    若無，則設為空字典，引擎會回傳 1.0
    actual_values = {}  # 實際情境下，應從任務日誌或監控系統獲取

    # 4. 初始化 KPI 引擎並計算綜合 KPI 分數
    kpi_engine = KPIEngine(db)
    kpi_score = kpi_engine.compute_kpi_score(agent, quarter, actual_values)

    # 5. 計算最終分潤
    final_share = amount * (agent.base_share_ratio / 100) * kpi_score

    # 6. 寫入帳本
    event = LedgerEvent(
        agent_id=agent_id,
        event_type=event_type,
        amount=amount,
        kpi_score=kpi_score,
        final_share=final_share,
        metadata=metadata
    )
    db.add(event)
    db.commit()
    db.refresh(event)

    # 7. （可選）將此次的實際值記錄到 kpi_scores，以便季度結算
    #    但通常 kpi_scores 是定期批量更新的，而非每次事件觸發

    return {
        "status": "recorded",
        "event_id": event.id,
        "kpi_score": kpi_score,
        "final_share": final_share
    }