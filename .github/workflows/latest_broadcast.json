🧩 Day 4 核心：run_news_pipeline.py（補上錯誤處理與完整日誌）

這是你一鍵執行的關鍵，必須能穩定回報成功或失敗。

```python
# run_news_pipeline.py
import asyncio
import json
import sys
import traceback
from datetime import datetime
from pathlib import Path

# 確保 agents 目錄在路徑中
sys.path.append(str(Path(__file__).parent))

from agents.news_bot import NewsBot
from agents.anchor_bot import AnchorBot
from agents.tts_bot import TTSBot

async def main():
    print(f"\n{'='*50}")
    print(f"🚀 Lightning AI News Pipeline 啟動")
    print(f"🕒 {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"{'='*50}\n")

    results = {
        "status": "pending",
        "steps": {},
        "timestamp": datetime.now().isoformat(),
        "headlines": [],
        "script": "",
        "audio_path": "",
        "error": None
    }

    try:
        # --- Step 1: NewsBot ---
        print("📰 [1/4] NewsBot: 抓取新聞...")
        news_bot = NewsBot()
        news_list = news_bot.fetch_latest(limit=3)
        results["steps"]["news_fetch"] = {"count": len(news_list), "status": "ok"}
        print(f"   ✅ 抓到 {len(news_list)} 則新聞")
        for i, item in enumerate(news_list, 1):
            print(f"      {i}. {item['headline'][:50]}...")

        # --- Step 2: AnchorBot ---
        print("\n✍️ [2/4] AnchorBot: 生成主播稿...")
        anchor_bot = AnchorBot()
        script = anchor_bot.generate_script(news_list)
        results["steps"]["script_gen"] = {"length": len(script), "status": "ok"}
        print(f"   ✅ 主播稿長度: {len(script)} 字")
        print(f"   📝 開頭: {script[:60]}...")

        # --- Step 3: TTSBot ---
        print("\n🗣️ [3/4] TTSBot: 語音合成...")
        tts_bot = TTSBot()
        audio_path = tts_bot.sync_speak(script)
        results["steps"]["tts_gen"] = {"path": audio_path, "status": "ok"}
        print(f"   ✅ 音檔已儲存: {audio_path}")

        # --- Step 4: 儲存結果 ---
        print("\n💾 [4/4] 儲存結果...")
        results["status"] = "completed"
        results["headlines"] = [n["headline"] for n in news_list]
        results["script"] = script
        results["audio_path"] = audio_path

        output_file = Path("storage/latest_broadcast.json")
        output_file.parent.mkdir(exist_ok=True)
        with open(output_file, "w", encoding="utf-8") as f:
            json.dump(results, f, ensure_ascii=False, indent=2)
        print(f"   ✅ 結果儲存至: {output_file}")

        print(f"\n{'='*50}")
        print("✅ Pipeline 全部完成！")
        print(f"🎧 收聽播報: {audio_path}")
        print(f"{'='*50}\n")
        return 0

    except Exception as e:
        print(f"\n❌ Pipeline 失敗: {str(e)}")
        traceback.print_exc()
        results["status"] = "failed"
        results["error"] = str(e)
        # 仍儲存錯誤狀態
        output_file = Path("storage/latest_broadcast.json")
        output_file.parent.mkdir(exist_ok=True)
        with open(output_file, "w", encoding="utf-8") as f:
            json.dump(results, f, ensure_ascii=False, indent=2)
        return 1

if __name__ == "__main__":
    exit_code = asyncio.run(main())
    sys.exit(exit_code)
```

